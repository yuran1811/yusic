{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": { "typeAware": true, "typeCheck": true },
  "plugins": ["import", "jsdoc", "node", "oxc", "promise", "typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "restriction": "error",
    "nursery": "off"
  },

  "rules": {
    "avoid-new": "off",
    "ban-ts-comment": "off",
    "button-has-type": "off",
    "capitalized-comments": "off",
    "complexity": ["error", { "max": 25 }],
    "curly": ["error", "all", "consistent"],
    "explicit-function-return-type": "off",
    "explicit-member-accessibility": "off",
    "explicit-module-boundary-types": "off",
    "exports-last": "off",
    "filename-case": "off",
    "func-names": "off",
    "func-style": ["error", "declaration", { "allowArrowFunctions": true }],
    "group-exports": "off",
    "id-length": ["error", { "min": 1, "max": 35 }],
    "import/unambiguous": "off",
    "init-declarations": "off",
    "max-classes-per-file": "off",
    "max-dependencies": ["error", { "max": 20 }],
    "max-lines-per-function": "off",
    "max-lines": "off",
    "max-params": ["error", { "max": 6 }],
    "max-statements": ["error", { "max": 35 }],
    "new-cap": "off",
    "no-anonymous-default-export": "off",
    "no-async-await": "off",
    "no-bitwise": "off",
    "no-console": "off",
    "no-continue": "off",
    "no-danger": "warn",
    "no-default-export": "off",
    "no-duplicate-imports": "off",
    "no-explicit-any": "warn",
    "no-extra-boolean-cast": "off",
    "no-extraneous-class": ["warn", { "allowWithDecorator": true }],
    "no-floating-promises": "off",
    "no-implicit-coercion": ["error", { "allow": ["!!", "+"] }],
    "no-importing-vitest-globals": "off",
    "no-inferrable-types": "off",
    "no-inline-comments": "off",
    "no-invalid-void-type": "off",
    "no-magic-numbers": "off",
    "no-map-spread": "off",
    "no-misused-promises": "off",
    "no-multi-comp": "off",
    "no-mutable-exports": "off",
    "no-named-as-default": "off",
    "no-named-export": "off",
    "no-namespace": "off",
    "no-negated-condition": "off",
    "no-nested-ternary": "off",
    "no-nodejs-modules": "off",
    "no-non-null-assertion": "off",
    "no-null": "off",
    "no-optional-chaining": "off",
    "no-param-reassign": "off",
    "no-plusplus": "off",
    "no-process-env": "off",
    "no-rest-spread-properties": "off",
    "no-ternary": "off",
    "no-unassigned-import": "off",
    "no-undef": "off",
    "no-undefined": "off",
    "no-unescaped-entities": "off",
    "no-unsafe-argument": "warn",
    "no-unsafe-assignment": "warn",
    "no-unsafe-call": "warn",
    "no-unsafe-member-access": "warn",
    "no-unsafe-return": "warn",
    "no-unsafe-type-assertion": "off",
    "no-use-before-define": "off",
    "only-export-components": "off",
    "only-throw-error": "off",
    "prefer-await-to-callbacks": "off",
    "prefer-await-to-then": "off",
    "prefer-default-export": "off",
    "prefer-global-this": "off",
    "prefer-lowercase-title": "off",
    "prefer-named-capture-group": "off",
    "prefer-readonly-parameter-types": "off",
    "prefer-response-static-json": "off",
    "prefer-tag-over-role": "off",
    "prefer-template": "warn",
    "prefer-top-level-await": "off",
    "require-await": "off",
    "sort-imports": [
      "error",
      {
        "ignoreMemberSort": true,
        "ignoreDeclarationSort": true
      }
    ],
    "sort-keys": "off",
    "strict-boolean-expressions": "off",
    "strict-void-return": "off",
    "switch-exhaustiveness-check": "off",
    "unicorn/no-abusive-eslint-disable": "off",
    "unicorn/no-array-for-each": "off",
    "unicorn/no-array-reduce": "off",
    "unicorn/number-literal-case": "off"
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": ["**/*.lock", "**/skills/**", ".github/scripts/**"]
}
