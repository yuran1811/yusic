{
  "name": "yusic",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/yuran1811/yusic#readme",
  "bugs": {
    "url": "https://github.com/yuran1811/yusic/issues"
  },
  "license": "MIT",
  "author": "yuran1811",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuran1811/yusic.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": "./dist/index.mjs",
  "scripts": {
    "@cli": "turbo run --filter=@yusic/cli",
    "@doc": "turbo run --filter=@yusic/doc",
    "build": "turbo run build --summarize && bun .github/scripts/build-sizes.ts",
    "clean": "bash ./scripts/clean.sh",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "[ -f .github/scripts/deps-manager.ts ] && bun .github/scripts/deps-manager.ts || true",
    "typecheck": "turbo run typecheck --summarize"
  },
  "dependencies": {
    "turbo": "catalog:"
  },
  "devDependencies": {
    "@octokit/rest": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "globby": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@clack/prompts": "^1.5.1",
    "@fuma-translate/react": "^0.0.3",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "fumadocs-core": "^16.9.1",
    "fumadocs-mdx": "^14.3.0",
    "fumadocs-ui": "^16.9.1",
    "globby": "^16.2.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  }
}
