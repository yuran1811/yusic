{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", ".source/**", "bundle/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "start": {
      "persistent": true,
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  },
  "globalEnv": [
    // CI variables
    "SKIP_ENV_VALIDATION",
    // Server variables
    "NODE_ENV",
    // Client variables
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_API_URL"
  ]
}
